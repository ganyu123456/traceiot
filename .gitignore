# ============================================================
# TraceIoT — .gitignore
# ============================================================

# ── .NET / C# ────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
*.swp
*.DS_Store
Thumbs.db

# 发布输出
publish/
out/

# NuGet
*.nupkg
*.snupkg
**/packages/
!**/packages/build/
nuget.config

# EF Core 迁移快照不忽略（需要提交），但忽略数据库文件
*.db
*.sqlite

# 运行时日志
Logs/
*.log

# ASP.NET Core Data Protection
DataProtection-Keys/

# 本地配置覆盖（含敏感信息，不提交）
appsettings.Local.json
**/appsettings.Development.json

# ── Node.js / 前端 ────────────────────────────────────────────
node_modules/
dist/
.pnp
.pnp.js
.yarn/install-state.gz

# Vite 缓存
.vite/
frontend/.vite/

# 测试覆盖率
coverage/
*.lcov

# ── Python / 模拟器 ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Docker ────────────────────────────────────────────────────
# 离线镜像包（体积巨大）
*.tar.gz
offline-deploy/

# ── IDE / 编辑器 ──────────────────────────────────────────────
.idea/
*.iml
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── 环境变量 / 密钥 ───────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── 临时文件 ──────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
